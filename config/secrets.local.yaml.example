# Local-only secret values.
#
# To use: copy this file to secrets.local.yaml (which is gitignored)
# and fill in the API keys for the providers you want to test against.
# Anything you don't fill in keeps the placeholder from secrets.yaml.

llm:
  # bedrock:
  #   aws_access_key_id: AKIA...
  #   aws_secret_access_key: ...
  # anthropic:
  #   api_key: sk-ant-...
  # alibaba:
  #   api_key: sk-...

# databases:
#   app_db:
#     url: postgresql+asyncpg://lumen:lumen@localhost:5432/app
#   warehouse_db:
#     url: postgresql+asyncpg://lumen:lumen@localhost:5432/warehouse
#   redis:
#     url: redis://localhost:6379

cube:
  api_secret: local-dev-secret-change-me

auth:
  jwt_signing_key: local-dev-only-replace-in-prod
