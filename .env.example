# --- AWS / Bedrock ---
AWS_PROFILE=omni-dev
ANTHROPIC_BEDROCK_REGION=us-east-1

# --- Databases ---
APP_DB_URL=postgresql+asyncpg://omni:omni@localhost:5432/app
WAREHOUSE_DB_URL=postgresql+asyncpg://omni:omni@localhost:5432/warehouse
REDIS_URL=redis://localhost:6379

# --- Cube ---
CUBE_API_URL=http://localhost:4000/cubejs-api/v1
CUBE_API_SECRET=local-dev-secret-change-me

# --- Local DuckDB warehouse (used by local_test/) ---
LOCAL_DUCKDB_PATH=./local_test/data/warehouse.duckdb

# --- Auth ---
JWT_SIGNING_KEY=local-dev-only-replace-in-prod
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Service ports ---
API_GATEWAY_PORT=8000
AI_SERVICE_PORT=8001
QUERY_SERVICE_PORT=8002
AUTH_SERVICE_PORT=8003
WORKSPACE_SERVICE_PORT=8004

# --- Service URLs (used by gateway to fan out) ---
AI_SERVICE_URL=http://localhost:8001
QUERY_SERVICE_URL=http://localhost:8002
AUTH_SERVICE_URL=http://localhost:8003
WORKSPACE_SERVICE_URL=http://localhost:8004

# --- Observability ---
LOG_LEVEL=DEBUG
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# --- Feature flags ---
USE_MOCK_LLM=false             # set true to bypass Bedrock for local smoke tests
